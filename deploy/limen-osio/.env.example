# Domains (DNS A records must point to this VM)
LANDING_DOMAIN=limen-os.io
SHELL_DOMAIN=io.limen-os.io

# ACME / Let's Encrypt contact email
ACME_EMAIL=you@example.com

# Shell auth (cookie-based session login)
LIMEN_AUTH_USER=limen
LIMEN_AUTH_PASS=change_me_strong_password

# Index page auth (generate hash: docker run --rm caddy:2-alpine caddy hash-password)
INDEX_USER=admin
INDEX_PASS_HASH=

# Timezone for Home Assistant
TZ=Europe/Athens

# Home Assistant
HA_ORIGIN=http://home-assistant:8123
HA_AGENT_SECRET=

# AI / search (optional)
ANTHROPIC_API_KEY=sk-ant-...
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=

# MQTT (optional)
LIMEN_MQTT_USER=
LIMEN_MQTT_PASS=
VITE_MQTT_WS_PORT=1884
