# Domains (must have DNS A records pointing to this VM)
PHD_DOMAIN=what-if.io
HUNT_DOMAIN=hunt.what-if.io
AUTH_DOMAIN=account.what-if.io

# ACME / Let's Encrypt contact email
ACME_EMAIL=you@example.com

# PostgreSQL
POSTGRES_PASSWORD=change_me_strong_password

# Zitadel (masterkey must be exactly 32 characters)
ZITADEL_MASTERKEY=MasterkeyNeedsToHave32Characters!!
ZITADEL_ADMIN_PASSWORD=Admin1234!

# Index page auth (generate hash: docker run --rm caddy:2-alpine caddy hash-password)
INDEX_USER=admin
INDEX_PASS_HASH=

# AI scoring (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-opus-4-7
