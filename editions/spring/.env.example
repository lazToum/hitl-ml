# Copy to .env and fill in real values before running.
# Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────
# Keep DATABASE_URL password in sync with POSTGRES_PASSWORD.
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgres://hunt:change_me@localhost:5432/treasure_hunt
REDIS_URL=redis://localhost:6379
# Use the pre-generated .sqlx/ cache so cargo build works without a live DB.
# Run `cargo sqlx prepare` after any SQL query change to regenerate it.
SQLX_OFFLINE=true

# ── OIDC (Zitadel) ────────────────────────────────────────────
# Issuer is the public URL Zitadel uses in the `iss` JWT claim.
OIDC_ISSUER=http://localhost:8180
# Internal Docker URL for JWKS fetching (Rust API inside Docker cannot reach localhost).
# Leave blank when running locally without Docker (discovery fallback kicks in).
OIDC_JWKS_URL=http://nginx:80/oauth/v2/keys

# ── Zitadel admin ─────────────────────────────────────────────
# Admin account created on first `docker compose up`.
# Login: admin@localhost:8180 / Admin1234!
ZITADEL_MASTERKEY=MasterkeyNeedsToHave32Characters
ZITADEL_ADMIN_PASSWORD=Admin1234!

# ── AI service ────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8001
AI_SERVICE_HOST_PORT=8001

# Provider is selected by the prefix in LLM_MODEL:
#   anthropic/claude-opus-4-7   → Anthropic  (LLM_API_KEY required)
#   openai/gpt-4o               → OpenAI     (LLM_API_KEY required)
#   ollama/llama3               → Ollama local text   (free, no key needed)
#   ollama/llava                → Ollama local vision (free, no key needed)
LLM_API_KEY=replace_me
LLM_MODEL=anthropic/claude-opus-4-7

# Ollama — only set if LLM_MODEL starts with "ollama/"
# OLLAMA_BASE_URL=http://localhost:11434

# ── Zitadel client credentials (used by the web dashboard) ────
# Run zitadel/setup.sh once to create the OIDC apps and get the client IDs.
VITE_OIDC_ISSUER=http://localhost:8180
VITE_OIDC_CLIENT_ID=<run zitadel/setup.sh to get this>
VITE_OIDC_REDIRECT_URI=http://localhost:5173/callback
# Pass these to Flutter with --dart-define when building/running mobile.
OIDC_CLIENT_ID=<run zitadel/setup.sh to get this>
OIDC_REDIRECT_URI=treasurehunt://oauth/callback

# Optional host-port overrides if 8080/8001 are already occupied locally.
RUST_API_HOST_PORT=8080

# ── Dev accounts (all use password: "Password1!") ────────────
# creator@example.com  — can create and manage hunts
# observer@example.com — can watch live sessions
# player@example.com   — regular player

# ── Google connector (production only) ────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
