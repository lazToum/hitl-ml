  "db_name": "PostgreSQL",
  "query": "SELECT h.id, h.title, h.status, h.created_at,\n                  COUNT(c.id) AS \"clue_count!: i64\"\n           FROM hunts h\n           LEFT JOIN clues c ON c.hunt_id = h.id\n           WHERE h.status = 'active'\n           GROUP BY h.id\n           ORDER BY h.created_at DESC",
