server {
    listen 80;
    server_name example.com;

    root /var/www/hitl/dist/site;
    index index.html;

    location = / {
        try_files /index.html =404;
    }

    location /overview/ {
        try_files $uri $uri/ /overview/index.html;
    }

    location /summer/ {
        try_files $uri $uri/ /summer/index.html;
    }

    location /autumn/ {
        try_files $uri $uri/ /autumn/index.html;
    }

    location /winter/ {
        try_files $uri $uri/ /winter/index.html;
    }

    location /reader/ {
        try_files $uri $uri/ /reader/index.html;
    }

    location /companion/ {
        try_files $uri $uri/ /companion/index.html;
    }

    location /spring/ {
        proxy_pass http://127.0.0.1:4173/;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /spring/api/ {
        proxy_pass http://127.0.0.1:8080/;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
